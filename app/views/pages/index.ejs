<!DOCTYPE html>
<html lang="pt-br">

<head>
    <meta charset="UTF-8">
    <meta http-equiv="X-UA-Compatible" content="IE=edge">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title> Integração com SGBD </title>
    <link rel="stylesheet" href="css/estilo.css">
</head>

<body>
   <h1>Lista de tarefas a fazer - 3C</h1>

    <button onclick="window.location='/cadastro'">Nova Tarefa</button>
    <button onclick="window.location='/tarefas-escondidas'">Ver Tarefas Escondidas</button>

    <br>
    <br>

   <table>
    <thead>
        <tr>
            <th>Código</th>
            <th>Tarefa</th>
            <th>Prazo</th>
            <th>Situação</th>
            <th>Ações</th>
        </tr>
    </thead>
    <tbody>
<% if(linhasTabela){
    let situacao = ["Cancelada", "Pendente","Iniciada","Finalizada","Em Atraso","Escondida"];
    
    linhasTabela.forEach((item)=>{
    %>
        <tr>
            <td><%= item.id_tarefa %></td>
            <td><%= item.nome_tarefa %></td>
            <td><%= moment(item.prazo_tarefa).format('L') %></td>
            <td><%= situacao[item.situacao_tarefa] %></td>       
            <td>
                <button onclick="window.location='/alterar?id=<%= item.id_tarefa %>'">Editar</button>
                <button onclick="if(confirm('Esconder essa tarefa?')) window.location='/esconder/<%= item.id_tarefa %>'">Esconder</button>
                <button onclick="if(confirm('Deletar permanentemente?')) window.location='/deletar/<%= item.id_tarefa %>'">Deletar</button>
            </td>       
        </tr>
    <% 
        });
        } else { %>
        <tr>
            <td colspan="5">Não há dados para exibir</td>
        </tr>    
    <% } %>    
    </tbody>
   </table>

   <%
        if(notificador){
            %>
            <nav>
                <ul>
                <%
                for(var i = 1; i<= notificador.totalPaginas; i++){
                        if(i == notificador.paginaAtual){
                            %>
                            <li> <a class="atual" href="?pagina=<%= i%>"><%= i%></a></li>
                            <%        
                        }else{
                            %>
                            <li> <a href="?pagina=<%= i%>"><%= i%></a></li>
                            <%        
                        }
                }
                %>
                </ul>
            </nav>    

            <%  
        }

    %>

</body>
</html>

</html>